<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- GŁÓWNY EKRAN -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#243A63"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/list_icon"
                android:layout_gravity="end|top"
                android:layout_margin="16dp"
                android:padding="8dp"
                android:contentDescription="Otwórz filtry" />
            <EditText
                android:id="@+id/etIngredient"
                android:layout_width="0dp"
                android:layout_height="67dp"
                android:layout_weight="1"
                android:hint="Składnik"
                android:textColorHint="@color/light_grey"
                android:textColor="@color/light_grey"
                android:backgroundTint="@color/light_grey"
                android:imeOptions="actionDone"
                android:inputType="text"
                android:maxLines="1"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnAdd"
                android:layout_width="wrap_content"
                android:layout_height="67dp"
                android:layout_marginStart="8dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:text="Dodaj"
                android:textSize="14sp"
                style="@style/AppButton_orange" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnFilters"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/filter"
            android:background="@android:color/transparent"
            android:padding="4dp"
            android:tint="@color/light_grey"
            android:layout_gravity="end"
            android:contentDescription="Filtry" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dodane składniki:"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/light_grey"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvIngredients"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <Button
            android:id="@+id/btnSearch"
            android:layout_width="289dp"
            android:layout_height="67dp"
            android:text="WYSZUKAJ"
            android:textSize="14sp"
            android:enabled="false"
            style="@style/AppButton_orange"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- LEWY DRAWER (MENU) -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start">

        <include layout="@layout/drawer_menu" />
    </LinearLayout>

    <!-- PRAWY DRAWER (FILTRY) -->
    <FrameLayout
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#1E2A47">

        <include layout="@layout/drawer_filters" />
    </FrameLayout>

</androidx.drawerlayout.widget.DrawerLayout>
