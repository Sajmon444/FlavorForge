<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/arrow_left"
            android:padding="8dp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="start"
            android:contentDescription="@string/back_button_desc" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            style="@style/AppTextTitle_orange"
            android:layout_marginBottom="24dp" />

        <!-- Language Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_light_grey"
            android:text="@string/settings_language"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/languageSpinner"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:popupBackground="@drawable/spinner_dropdown_bg"
            android:spinnerMode="dropdown"
            android:overlapAnchor="false"
            android:layout_marginBottom="24dp" />

        <!-- Unit Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_light_grey"
            android:text="@string/settings_units"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/unitSpinner"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/spinner_bg"
            android:popupBackground="@drawable/spinner_dropdown_bg"
            android:spinnerMode="dropdown"
            android:overlapAnchor="false"
            android:layout_marginBottom="24dp" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_light_grey"
            android:text="@string/settings_description"
            android:layout_marginBottom="16dp" />

        <!-- Slider 1 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_light_grey"
            android:text="@string/settings_spice"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/spiceSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Slider 2 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_light_grey"
            android:text="@string/settings_time"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/timeSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Slider 3 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_light_grey"
            android:text="@string/settings_health"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/healthSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- Button -->
        <Button
            android:id="@+id/btnApplySettings"
            style="@style/AppButton_orange"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/apply_settings"
            android:layout_marginTop="32dp" />

    </LinearLayout>
</ScrollView>