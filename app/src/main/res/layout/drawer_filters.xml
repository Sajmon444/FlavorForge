<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:layout_gravity="end"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filters_title"
            style="@style/AppTextTitle_orange"
            android:layout_marginBottom="32dp" />

        <!-- POZIOM TRUDNOŚCI -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_title"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cbEasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_easy"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_medium"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbHard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_hard"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey"
            android:layout_marginVertical="24dp" />

        <!-- CZAS PRZYGOTOWANIA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/time_title"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rgPreparationTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbTime30"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/time_30"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange" />

            <RadioButton
                android:id="@+id/rbTime60"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/time_60"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange" />

            <RadioButton
                android:id="@+id/rbTimeAny"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/time_any"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange"
                android:checked="true" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey"
            android:layout_marginVertical="24dp" />

        <!-- DIETA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diet_title"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cbVege"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diet_vege"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbVegan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diet_vegan"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbGlutenFree"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diet_gluten_free"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="32dp" />

        <Button
            android:id="@+id/btnApplyFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppButton_orange"
            android:text="@string/apply_filters"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClearFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:text="@string/clear_filters"
            style="@style/AppTextNormal_light_grey"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>