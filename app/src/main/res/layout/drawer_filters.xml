<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="300dp"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true"
    android:layout_gravity="end"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/filters_title"
            style="@style/AppTextTitle_orange"
            android:layout_marginBottom="32dp" />

        <!-- POZIOM TRUDNOŚCI -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_title"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cbEasy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_easy"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbMedium"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_medium"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbHard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/difficulty_hard"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey"
            android:layout_marginVertical="24dp" />

        <!-- CZAS PRZYGOTOWANIA -->
        <TextView
            android:id="@+id/tvFilterTimeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            tools:text="Max czas przygotowania: 180 min" />

        <SeekBar
            android:id="@+id/sbFilterTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="12"
            android:progress="12"
            android:thumbTint="@color/orange"
            android:progressTint="@color/orange"
            android:progressBackgroundTint="@color/light_grey"
            android:layout_marginBottom="24dp" />

        <!-- KALORYCZNOŚĆ -->
        <TextView
            android:id="@+id/tvFilterCaloriesLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"
            tools:text="Max kaloryczność: 3000 kcal" />

        <SeekBar
            android:id="@+id/sbFilterCalories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="54"
            android:progress="54"
            android:thumbTint="@color/orange"
            android:progressTint="@color/orange"
            android:progressBackgroundTint="@color/light_grey" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey"
            android:layout_marginVertical="24dp" />

        <!-- DIETA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/diet_title"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <RadioGroup
            android:id="@+id/rgDiet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/rbDietVege"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/diet_vege"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange" />

            <RadioButton
                android:id="@+id/rbDietVegan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/diet_vegan"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange" />

            <RadioButton
                android:id="@+id/rbDietMeat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/diet_meat"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange" />

            <RadioButton
                android:id="@+id/rbDietFish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/diet_fish"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange" />

            <RadioButton
                android:id="@+id/rbDietAny"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/diet_any"
                style="@style/AppTextNormal_light_grey"
                android:buttonTint="@color/orange"
                android:checked="true" />
        </RadioGroup>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/grey"
            android:layout_marginVertical="24dp" />

        <!-- RODZAJ POSIŁKU -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/meal_title"
            style="@style/AppTextNormal_orange"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cbMealBreakfast"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/meal_breakfast"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbMealLunch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/meal_lunch"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbMealDinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/meal_dinner"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbMealDessert"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/meal_dessert"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <CheckBox
            android:id="@+id/cbMealSnacks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/meal_snacks"
            style="@style/AppTextNormal_light_grey"
            android:buttonTint="@color/orange" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="32dp" />

        <Button
            android:id="@+id/btnApplyFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/AppButton_orange"
            android:text="@string/apply_filters"
            android:textSize="18sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClearFilters"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:text="@string/clear_filters"
            style="@style/AppTextNormal_light_grey"
            android:textAllCaps="false" />

    </LinearLayout>
</ScrollView>