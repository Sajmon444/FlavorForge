<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Pasek górny (Back + Favorite) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Wróć"
            android:padding="8dp"
            android:layout_alignParentStart="true"
            android:src="@drawable/arrow_left" />

        <ImageView
            android:id="@+id/btnFavorite"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Ulubione"
            android:padding="8dp"
            android:layout_alignParentEnd="true"
            android:src="@drawable/love"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- Nazwa przepisu -->
            <TextView
                android:id="@+id/tvRecipeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:textColor="@color/light_grey"
                android:textSize="28sp"
                android:textStyle="bold"
                tools:text="Jajecznica" />

            <!-- Obrazek przepisu -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivRecipeImage"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginBottom="24dp"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedCornersImage"
                tools:src="@tools:sample/backgrounds/scenic" />

            <!-- Opis -->
            <TextView
                android:id="@+id/tvRecipeDescription"
                style="@style/AppTextNormal_light_grey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:lineSpacingExtra="4dp"
                tools:text="Proste śniadanie białkowe." />

            <!-- Sekcja instrukcji -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="Instrukcje:"
                android:textColor="@color/orange"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvRecipeInstructions"
                style="@style/AppTextNormal_light_grey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="6dp"
                tools:text="1. Rozbij jajka.\n2. Smaż na maśle." />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
