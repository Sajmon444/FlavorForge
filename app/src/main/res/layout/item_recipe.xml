<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/clRecipe"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    android:background="@drawable/rounded_button"
    android:backgroundTint="@color/orange"
    android:clickable="true"
    android:focusable="true"
    android:padding="8dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivRecipe"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/RoundedCornersImage"
        tools:src="@tools:sample/backgrounds/scenic" />

    <TextView
        android:id="@+id/tvRecipeTitle"
        style="@style/AppTextNormal_light_grey"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/ivRecipe"
        app:layout_constraintTop_toTopOf="@id/ivRecipe"
        tools:text="Recipe Title" />

    <TextView
        android:id="@+id/tvRecipeDescription"
        style="@style/AppTextNormal_light_grey"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="3"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/ivRecipe"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvRecipeTitle"
        app:layout_constraintTop_toBottomOf="@id/tvRecipeTitle"
        tools:text="This is a short description of the recipe to show how it looks in the list." />

</androidx.constraintlayout.widget.ConstraintLayout>